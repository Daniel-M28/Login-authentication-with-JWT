{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",      //origen de los archivos TypeScript: ./src
     "outDir": "./dist",      //destino de los archivos compilados: ./dist

    // Environment Settings
 
    "target": "ES2022",        //Le dice a TypeScript a qué versión de JavaScript compilar
    "module": "nodenext",      //Le dice a TypeScript qué sistema de módulos usar. "nodenext" es para Node.js con soporte para módulos ES.
    "moduleResolution": "NodeNext",  
    "types": [],             // Especifica los tipos que se incluirán en la compilación. En este caso, se deja vacío para no incluir ningún tipo adicional.
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "skipLibCheck": true,
  }
}
